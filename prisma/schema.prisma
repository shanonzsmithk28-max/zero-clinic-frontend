generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Booking {
  id          Int      @id @default(autoincrement())
  name        String
  email       String
  phone       String
  nationality String
  hospital    String?
  department  String?
  symptom     String
  preferredDate String?
  notes       String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
}

model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}
